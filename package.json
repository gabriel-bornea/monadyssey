{
  "name": "monadyssey-fp",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "license": "MIT",
  "version": "1.15.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabriel-bornea/monadyssey"
  },
  "keywords": [
    "functional programming",
    "typescript"
  ],
  "author": "Gabriel Bornea",
  "contributors": [
    {
      "name": "Tiberiu Tofan"
    }
  ],
  "scripts": {
    "build": "npm run format && tsc && npm run typecheck:tests && npm run build:parallel",
    "build:packages": "npm run build --workspaces",
    "build:parallel": "concurrently \"npm run build --workspace=packages/monadyssey-core\" \"npm run build --workspace=packages/monadyssey-fetch\"",
    "typecheck:tests": "concurrently \"tsc --noEmit -p packages/monadyssey-core/tsconfig.spec.json\" \"tsc --noEmit -p packages/monadyssey-fetch/tsconfig.spec.json\"",
    "format": "npm run lint:fix && npm run prettier:fix",
    "test": "jest --env=node --verbose --coverage --detectOpenHandles --forceExit",
    "lint": "eslint \"packages/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"packages/**/*.{ts,tsx}\" --fix",
    "prettier": "prettier \"packages/**/*.{ts,tsx}\" --check",
    "prettier:fix": "prettier \"packages/**/*.{ts,tsx}\" --write"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vite-plugin-dts": "^4.5.4"
  }
}
